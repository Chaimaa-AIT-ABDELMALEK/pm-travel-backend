    {
      "parameters": {
        "jsCode": "const waitData = $('Wait2').first().json;\n\n// Nettoyer le contenu pour éviter les caractères de contrôle\nconst contenu = (waitData.contenu || '').replace(/[\\x00-\\x1F\\x7F]/g, ' ').trim();\n\nreturn [{\n  json: {\n    db_post_id: waitData.id,\n    plateforme: 'linkedin',\n    contenu: contenu\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
