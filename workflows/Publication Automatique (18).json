      "id": "f664543b-be89-45a0-9be0-c1f46b2d68de",
      "name": "Code in JavaScript3"
    },
    {
      "parameters": {
        "jsCode": "const data = $('Wait2').first().json;\n\n// Nettoyer complètement le contenu - enlever tous les caractères spéciaux\nlet cleanContent = (data.contenu || '')\n  .replace(/\\n/g, ' ')      // Remplacer les retours à la ligne par des espaces\n  .replace(/\\r/g, ' ')      // Remplacer les retours chariot\n  .replace(/\\t/g, ' ')      // Remplacer les tabulations\n  .replace(/[^\\x20-\\x7E]/g, '') // Enlever les caractères non ASCII\n  .trim();\n\n// Ajouter un identifiant unique\nconst timestamp = Date.now();\nconst finalContent = cleanContent + ` #PMTravel_${timestamp}`;\n\nreturn [{\n  json: {\n    id: data.id,\n    plateforme: data.plateforme,\n    contenu: finalContent\n  }\n}];"
      },
